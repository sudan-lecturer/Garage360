# Garage360 Environment Configuration
# Copy this file to .env and fill in the values

# ===========================================
# Database
# ===========================================
DATABASE_URL=postgres://postgres:postgres@localhost:5432/control
CONTROL_DATABASE_URL=postgres://postgres:postgres@localhost:5432/control

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# MinIO / S3 Storage
# ===========================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=garage360

# ===========================================
# JWT Authentication
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=7

# ===========================================
# Application
# ===========================================
APP_ENV=development
APP_PORT=8080
RUST_LOG=debug

# ===========================================
# Email (Sparrow SMS for Nepal)
# ===========================================
# Email SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Garage360

# SMS (Sparrow SMS)
SPARROW_SMS_TOKEN=
SPARROW_SMS_SENDER_ID=

# ===========================================
# CORS
# ===========================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# File Upload
# ===========================================
MAX_UPLOAD_SIZE_MB=10
PHOTO_COMPRESSION_QUALITY=80
