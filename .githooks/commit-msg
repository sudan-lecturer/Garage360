#!/bin/sh

set -eu

commit_msg_file="$1"
first_line="$(sed -n '1p' "$commit_msg_file")"

pattern='^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\([a-z0-9._/-]+\))?(!)?: .+'

if printf '%s\n' "$first_line" | grep -Eq "$pattern"; then
  exit 0
fi

cat <<'EOF'
ERROR: Commit message must follow Conventional Commits.

Expected format:
  type(scope): short summary

Examples:
  feat(api): add tenant readiness check
  fix(web): handle expired access token
  docs(repo): document docker workflow
  build(docker): standardize local compose commands

Allowed types:
  build, chore, ci, docs, feat, fix, perf, refactor, revert, style, test
EOF

exit 1
